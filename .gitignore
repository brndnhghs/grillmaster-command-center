.venv/
.venv-test/   # throwaway test venv (uv) — not the project's real .venv
__pycache__/
*.pyc
.DS_Store
*.sqlite3
**/data/*
# Curated learned artifact (dead-param blacklist the generator consumes to avoid
# wiring drivers onto inert controls). Ship it so fresh clones start with a
# populated blacklist instead of empty. Genomes/ratings/cost models stay ignored.
!**/data/driver-dead-params.json
# Spatial-param records: the A/B/C/D ledger, the probe report, and the
# attempt log the migration loop reads to stay monotonic. Tracked for the same
# reason as the blacklist above — they are curated state a fresh clone needs,
# and regenerating the attempt log means re-running every failed migration.
!**/data/spatial/
!**/data/spatial/*
noise_output/
_grid_params/
*.bak
*.corrupted
*.nd-bak-*.py

# Generated media — outputs only, never source assets
image_pipeline/output/
*.mp4
*.png
*.jpg
*.jpeg
*.gif
*.svg

# NOTE: deliberately NOT ignoring *.html / *.txt globally — the UI
# (ui/index.html) and requirements.txt are tracked source. Output text
# and HTML land under image_pipeline/output/ which is ignored above.
*.egg-info/

# Node.js dependencies (installed, never committed)
node_modules/
